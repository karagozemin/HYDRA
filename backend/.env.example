# Agent private keys (fund each with ~0.1 MON for gas)
AGENT1_KEY=0x...  # Security Agent
AGENT2_KEY=0x...  # Risk Agent
AGENT3_KEY=0x...  # Portfolio Agent

# GROQ API key (free at console.groq.com)
GROQ_API_KEY=gsk_...

# Deployed contract address (set after forge deploy)
CONTRACT_ADDRESS=0x...

# Owner wallet address (for portfolio balance check)
OWNER_ADDRESS=0x...

# Optional: set to true for hardcoded demo responses (no LLM calls)
USE_MOCK_AGENTS=false

# Optional: override default RPC
# RPC_URL=https://testnet-rpc.monad.xyz
